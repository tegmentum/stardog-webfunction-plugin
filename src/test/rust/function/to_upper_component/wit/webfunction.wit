// Test-only WIT world mirroring the type shapes of the base
// tegmentum:webfunction@0.1.0 (see submodule wit/base/) and Stardog
// overlay stardog:webfunction@0.3.0 (see submodule wit/overlay/).
//
// The world's flat exports (evaluate / aggregate-step / aggregate-finish
// / cardinality-estimate / doc) preserve the dispatch surface
// StardogWasmInstance currently drives; the full sparql-extension world
// migration (extension.call + aggregate resource lifecycle) is deferred
// because it requires resource-handle plumbing in the Java-side
// webassembly4j API that has not yet been designed.
//
// Type-level changes carried over from the base+overlay WIT:
//   * `value` → `term` (adds `triple(quoted-triple)` arm)
//   * `literal.label` → `literal.value`
//   * `literal.lang` → `literal.language`
//   * `literal.datatype` typed `option<iri>` (nullable)
//   * `binding.name` → `binding.variable`
package stardog:webfunction-test@0.3.0;

interface types {
    type iri = string;

    record literal {
        value: string,
        datatype: option<iri>,
        language: option<string>,
    }

    variant flat-term {
        named-node(iri),
        blank-node(string),
        literal(literal),
    }

    record quoted-triple {
        subject: flat-term,
        predicate: flat-term,
        object: flat-term,
    }

    variant term {
        named-node(iri),
        blank-node(string),
        literal(literal),
        triple(quoted-triple),
    }

    record binding {
        variable: string,
        value: term,
    }

    record binding-sets {
        vars: list<string>,
        rows: list<list<binding>>,
    }

    enum accuracy {
        verified,
        injected,
        accurate,
        mostly-accurate,
        probably-accurate,
        possibly-off,
        probably-off,
        random,
    }

    record cardinality {
        value: f64,
        accuracy: accuracy,
    }
}

world webfunction {
    use types.{term, binding-sets, cardinality};

    export evaluate: func(args: list<term>) -> result<binding-sets, string>;
    export aggregate-step: func(args: list<term>, mult: u64) -> result<_, string>;
    export aggregate-finish: func() -> result<binding-sets, string>;
    export cardinality-estimate: func(input: cardinality, args: list<term>) -> result<cardinality, string>;
    export doc: func() -> binding-sets;
}
