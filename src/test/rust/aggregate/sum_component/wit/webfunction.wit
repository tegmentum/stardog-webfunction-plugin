// See src/test/rust/function/to_upper_component/wit/webfunction.wit
// for the rationale behind the test-only package layout. Type
// definitions mirror tegmentum:webfunction@0.1.0 (base) and
// stardog:webfunction@0.3.0 (overlay); the flat world exports
// preserve the dispatch surface StardogWasmInstance currently drives.
//
// Aggregate-specific note: the full sparql-extension aggregate world
// uses a resource `aggregate-state` with `step` + `finish` methods.
// The Java-side webassembly4j binding does not yet expose invocation
// of WIT resource methods; this crate stays on the flat
// aggregate-step / aggregate-finish exports until that infrastructure
// lands. The tegmentum types (term, binding, literal.value/language,
// binding.variable) are otherwise adopted verbatim.
package stardog:webfunction-test@0.3.0;

interface types {
    type iri = string;

    record literal {
        value: string,
        datatype: option<iri>,
        language: option<string>,
    }

    variant flat-term {
        named-node(iri),
        blank-node(string),
        literal(literal),
    }

    record quoted-triple {
        subject: flat-term,
        predicate: flat-term,
        object: flat-term,
    }

    variant term {
        named-node(iri),
        blank-node(string),
        literal(literal),
        triple(quoted-triple),
    }

    record binding {
        variable: string,
        value: term,
    }

    record binding-sets {
        vars: list<string>,
        rows: list<list<binding>>,
    }

    enum accuracy {
        verified,
        injected,
        accurate,
        mostly-accurate,
        probably-accurate,
        possibly-off,
        probably-off,
        random,
    }

    record cardinality {
        value: f64,
        accuracy: accuracy,
    }
}

world webfunction {
    use types.{term, binding-sets, cardinality};

    export evaluate: func(args: list<term>) -> result<binding-sets, string>;
    export aggregate-step: func(args: list<term>, mult: u64) -> result<_, string>;
    export aggregate-finish: func() -> result<binding-sets, string>;
    export cardinality-estimate: func(input: cardinality, args: list<term>) -> result<cardinality, string>;
    export doc: func() -> binding-sets;
}
